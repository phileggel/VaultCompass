  "query": "\n            SELECT \n                a.id, a.name, a.reference, a.asset_class, a.currency, a.risk_level,\n                c.id as category_id, \n                c.name as category_name\n            FROM assets a\n            JOIN categories c ON a.category_id = c.id\n            WHERE a.id = ? \n                AND a.is_deleted = 0\n                AND c.is_deleted = 0\n            ",
