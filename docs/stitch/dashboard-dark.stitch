<!DOCTYPE html>

<html class="dark" lang="fr"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>The Clinical Atelier - Dashboard</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary-container": "#6750a4",
                        "error": "#ba1a1a",
                        "on-primary-fixed": "#22005d",
                        "surface-container-low": "#1D1B20",
                        "surface-container-high": "#211F26",
                        "on-background": "#E6E1E5",
                        "tertiary": "#765b00",
                        "on-tertiary-fixed": "#241a00",
                        "on-tertiary": "#ffffff",
                        "primary-fixed": "#e9ddff",
                        "outline-variant": "rgba(203, 196, 210, 0.2)",
                        "on-error-container": "#93000a",
                        "tertiary-container": "#c9a74d",
                        "on-primary-container": "#e0d2ff",
                        "on-secondary": "#ffffff",
                        "tertiary-fixed-dim": "#e7c365",
                        "secondary-fixed-dim": "#cdc0e9",
                        "outline": "#7a7582",
                        "surface-variant": "#49454F",
                        "background": "#141218",
                        "surface-container-highest": "#36343B",
                        "on-error": "#ffffff",
                        "surface-bright": "#1D1B20",
                        "on-surface-variant": "#CAC4D0",
                        "on-secondary-container": "#D0BCFF",
                        "secondary": "#CCC2DC",
                        "on-surface": "#E6E1E5",
                        "surface-dim": "#141218",
                        "inverse-surface": "#E6E1E5",
                        "primary": "#D0BCFF",
                        "secondary-container": "#4A4458",
                        "on-tertiary-fixed-variant": "#594400",
                        "on-tertiary-container": "#FFDF93",
                        "on-primary": "#381E72",
                        "inverse-on-surface": "#313033",
                        "surface-container-lowest": "#000000",
                        "on-secondary-fixed-variant": "#CCC2DC",
                        "inverse-primary": "#6750A4",
                        "tertiary-fixed": "#FFDF93",
                        "surface-container": "#211F26",
                        "primary-fixed-dim": "#D0BCFF",
                        "surface-tint": "#D0BCFF",
                        "surface": "#141218",
                        "on-secondary-fixed": "#1D192B",
                        "error-container": "#8C1D18",
                        "secondary-fixed": "#E8DEF8"
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.75rem",
                        "xl": "1rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-card {
            background: rgba(33, 31, 38, 0.7);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .custom-scrollbar::-webkit-scrollbar {
            height: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #49454F;
            border-radius: 10px;
        }
    </style>
</head>
<body class="bg-background text-on-background font-body flex flex-col min-h-screen">
<!-- TopAppBar -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-[#1D1B20] text-[#E6E1E5] border-b border-outline-variant/10 shadow-lg">
<div class="flex items-center gap-4">
<button class="p-2 hover:bg-white/10 transition-colors duration-200 rounded-full">
<span class="material-symbols-outlined" data-icon="menu">menu_open</span>
</button>
<span class="font-headline font-bold text-lg tracking-tight">The Clinical Atelier</span>
</div>
<div class="absolute left-1/2 -translate-x-1/2 hidden md:block">
<h1 class="font-headline font-extrabold text-xl tracking-wider">Dashboard</h1>
</div>
<div class="flex items-center gap-2">
<button class="p-2 hover:bg-white/10 transition-colors duration-200 rounded-full">
<span class="material-symbols-outlined" data-icon="dark_mode">dark_mode</span>
</button>
</div>
</header>
<!-- SideNavBar -->
<nav class="hidden lg:flex flex-col py-6 gap-4 h-screen fixed left-0 top-0 bg-[#1D1B20] text-[#D0BCFF] z-40 w-20 border-r border-outline-variant/10">
<!-- Spacer for top app bar height -->
<div class="h-16 shrink-0"></div>
<div class="flex flex-col gap-2">
<a class="flex items-center gap-3 py-3 bg-[#4F378A] text-[#EADDFF] font-bold transition-all duration-200 justify-center rounded-r-xl mr-2" href="#">
<span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
</a>
<a class="flex items-center gap-3 py-3 text-[#CAC4D0] hover:bg-surface-container-highest transition-all duration-200 justify-center rounded-r-xl mr-2" href="#">
<span class="material-symbols-outlined" data-icon="group">group</span>
</a>
<a class="flex items-center gap-3 py-3 text-[#CAC4D0] hover:bg-surface-container-highest transition-all duration-200 justify-center rounded-r-xl mr-2" href="#">
<span class="material-symbols-outlined" data-icon="calendar_today">calendar_today</span>
</a>
<a class="flex items-center gap-3 py-3 text-[#CAC4D0] hover:bg-surface-container-highest transition-all duration-200 justify-center rounded-r-xl mr-2" href="#">
<span class="material-symbols-outlined" data-icon="medical_services">medical_services</span>
</a>
<a class="flex items-center gap-3 py-3 text-[#CAC4D0] hover:bg-surface-container-highest transition-all duration-200 justify-center rounded-r-xl mr-2" href="#">
<span class="material-symbols-outlined" data-icon="settings">settings</span>
</a>
</div>
</nav>
<!-- Main Content Area -->
<main class="pt-16 min-h-screen bg-background lg:ml-20 flex flex-col">
<!-- Sub-Header -->
<section class="px-8 py-10 bg-surface-container-low/30 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
<div>
<h2 class="font-headline font-extrabold text-3xl text-on-background tracking-tight">Tableau de bord</h2>
<p class="text-on-surface-variant font-medium mt-1">Analyse comparative des performances cliniques</p>
</div>
<div class="flex items-center gap-3 bg-surface-container-highest px-4 py-2 rounded-full border border-outline-variant">
<span class="text-primary font-bold">2025</span>
<span class="w-1 h-1 rounded-full bg-outline"></span>
<span class="text-on-surface-variant text-sm font-medium">Exercice en cours</span>
</div>
</section>
<!-- Bento Grid Dashboard -->
<div class="px-8 pb-12 grid grid-cols-1 xl:grid-cols-2 gap-8 flex-grow">
<!-- Card 1: Paiements 2025 -->
<div class="bg-surface-container glass-card rounded-xl p-6 flex flex-col">
<div class="flex justify-between items-center mb-6">
<h3 class="font-headline font-bold text-xl flex items-center gap-3">
<span class="material-symbols-outlined text-primary" data-icon="payments">payments</span>
                        Paiements 2025
                    </h3>
<span class="text-[#EADDFF] font-semibold px-3 py-1 bg-[#4F378A]/40 rounded-full text-xs uppercase tracking-wider">Actuel</span>
</div>
<div class="overflow-x-auto custom-scrollbar">
<table class="w-full text-left text-sm border-collapse">
<thead class="text-on-surface-variant font-label border-b border-outline-variant/10">
<tr>
<th class="py-4 px-2 font-semibold">Mois</th>
<th class="py-4 px-2 text-right font-semibold">Patients</th>
<th class="py-4 px-2 text-right font-semibold">Consult.</th>
<th class="py-4 px-2 text-right font-semibold">Télécons.</th>
<th class="py-4 px-2 text-right font-semibold">Visite</th>
<th class="py-4 px-2 text-right font-bold text-on-surface">Total (€)</th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant/5">
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Janvier</td>
<td class="py-4 px-2 text-right">142</td>
<td class="py-4 px-2 text-right">98</td>
<td class="py-4 px-2 text-right">32</td>
<td class="py-4 px-2 text-right">12</td>
<td class="py-4 px-2 text-right font-bold text-primary">4 210</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Février</td>
<td class="py-4 px-2 text-right">135</td>
<td class="py-4 px-2 text-right">85</td>
<td class="py-4 px-2 text-right">40</td>
<td class="py-4 px-2 text-right">10</td>
<td class="py-4 px-2 text-right font-bold text-primary">3 980</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Mars</td>
<td class="py-4 px-2 text-right">158</td>
<td class="py-4 px-2 text-right">110</td>
<td class="py-4 px-2 text-right">30</td>
<td class="py-4 px-2 text-right">18</td>
<td class="py-4 px-2 text-right font-bold text-primary">4 850</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Avril</td>
<td class="py-4 px-2 text-right">124</td>
<td class="py-4 px-2 text-right">78</td>
<td class="py-4 px-2 text-right">42</td>
<td class="py-4 px-2 text-right">4</td>
<td class="py-4 px-2 text-right font-bold text-primary">3 620</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Mai</td>
<td class="py-4 px-2 text-right">148</td>
<td class="py-4 px-2 text-right">102</td>
<td class="py-4 px-2 text-right">35</td>
<td class="py-4 px-2 text-right">11</td>
<td class="py-4 px-2 text-right font-bold text-primary">4 440</td>
</tr>
<tr>
<td class="py-6 px-2 italic text-on-surface-variant/50 text-center" colspan="6">
<div class="flex items-center justify-center gap-2">
<span class="material-symbols-outlined text-base" data-icon="hourglass_empty">hourglass_empty</span>
                                        Données prévisionnelles Juin-Déc en attente
                                    </div>
</td>
</tr>
</tbody>
</table>
</div>
</div>
<!-- Card 2: Paiements 2024 -->
<div class="bg-surface-container-low/40 border border-outline-variant/10 rounded-xl p-6 flex flex-col opacity-90 transition-opacity hover:opacity-100">
<div class="flex justify-between items-center mb-6">
<h3 class="font-headline font-bold text-xl flex items-center gap-3 text-on-surface-variant">
<span class="material-symbols-outlined" data-icon="history">history</span>
                        Paiements 2024
                    </h3>
<span class="text-on-surface-variant/70 font-semibold px-3 py-1 bg-surface-container-highest rounded-full text-xs uppercase tracking-wider">Archivé</span>
</div>
<div class="overflow-x-auto custom-scrollbar">
<table class="w-full text-left text-sm border-collapse">
<thead class="text-on-surface-variant/60 font-label border-b border-outline-variant/10">
<tr>
<th class="py-4 px-2 font-semibold">Mois</th>
<th class="py-4 px-2 text-right font-semibold">Patients</th>
<th class="py-4 px-2 text-right font-semibold">Consult.</th>
<th class="py-4 px-2 text-right font-semibold">Télécons.</th>
<th class="py-4 px-2 text-right font-semibold">Visite</th>
<th class="py-4 px-2 text-right font-bold">Total (€)</th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant/5">
<tr class="bg-primary/5">
<td class="py-4 px-2 font-semibold text-primary">Annuel</td>
<td class="py-4 px-2 text-right text-primary">1 842</td>
<td class="py-4 px-2 text-right text-primary">1 240</td>
<td class="py-4 px-2 text-right text-primary">412</td>
<td class="py-4 px-2 text-right text-primary">190</td>
<td class="py-4 px-2 text-right font-extrabold text-primary">54 280</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2">Décembre</td>
<td class="py-4 px-2 text-right">156</td>
<td class="py-4 px-2 text-right">98</td>
<td class="py-4 px-2 text-right">45</td>
<td class="py-4 px-2 text-right">13</td>
<td class="py-4 px-2 text-right font-bold">4 610</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2">Novembre</td>
<td class="py-4 px-2 text-right">148</td>
<td class="py-4 px-2 text-right">105</td>
<td class="py-4 px-2 text-right">32</td>
<td class="py-4 px-2 text-right">11</td>
<td class="py-4 px-2 text-right font-bold">4 340</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2">Octobre</td>
<td class="py-4 px-2 text-right">162</td>
<td class="py-4 px-2 text-right">112</td>
<td class="py-4 px-2 text-right">38</td>
<td class="py-4 px-2 text-right">12</td>
<td class="py-4 px-2 text-right font-bold">4 890</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2">Septembre</td>
<td class="py-4 px-2 text-right">151</td>
<td class="py-4 px-2 text-right">95</td>
<td class="py-4 px-2 text-right">40</td>
<td class="py-4 px-2 text-right">16</td>
<td class="py-4 px-2 text-right font-bold">4 470</td>
</tr>
</tbody>
</table>
</div>
</div>
<!-- Card 3: Actes 2025 -->
<div class="bg-surface-container glass-card rounded-xl p-6 flex flex-col">
<div class="flex justify-between items-center mb-6">
<h3 class="font-headline font-bold text-xl flex items-center gap-3">
<span class="material-symbols-outlined text-primary" data-icon="medical_information">medical_information</span>
                        Actes 2025
                    </h3>
</div>
<div class="grid grid-cols-2 gap-4 mb-8">
<div class="bg-surface-container-high/60 p-5 rounded-xl border border-outline-variant/5">
<p class="text-[10px] text-on-surface-variant font-bold uppercase tracking-[0.1em]">Actes Cliniques</p>
<p class="text-3xl font-headline font-extrabold mt-1 text-primary">607</p>
</div>
<div class="bg-surface-container-high/60 p-5 rounded-xl border border-outline-variant/5">
<p class="text-[10px] text-on-surface-variant font-bold uppercase tracking-[0.1em]">Moyenne / Mois</p>
<p class="text-3xl font-headline font-extrabold mt-1 text-secondary">121</p>
</div>
</div>
<div class="overflow-x-auto custom-scrollbar">
<table class="w-full text-left text-sm border-collapse">
<thead class="text-on-surface-variant font-label border-b border-outline-variant/10">
<tr>
<th class="py-4 px-2 font-semibold">Mois</th>
<th class="py-4 px-2 text-right font-semibold">Actes Total</th>
<th class="py-4 px-2 text-right font-semibold">Échographies</th>
<th class="py-4 px-2 text-right font-semibold">Sutures</th>
<th class="py-4 px-2 text-right font-semibold">ECG</th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant/5">
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Janvier</td>
<td class="py-4 px-2 text-right font-bold text-primary">128</td>
<td class="py-4 px-2 text-right">42</td>
<td class="py-4 px-2 text-right">12</td>
<td class="py-4 px-2 text-right">74</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Février</td>
<td class="py-4 px-2 text-right font-bold text-primary">115</td>
<td class="py-4 px-2 text-right">38</td>
<td class="py-4 px-2 text-right">8</td>
<td class="py-4 px-2 text-right">69</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Mars</td>
<td class="py-4 px-2 text-right font-bold text-primary">142</td>
<td class="py-4 px-2 text-right">51</td>
<td class="py-4 px-2 text-right">15</td>
<td class="py-4 px-2 text-right">76</td>
</tr>
</tbody>
</table>
</div>
</div>
<!-- Card 4: Actes 2024 -->
<div class="bg-surface-container glass-card rounded-xl p-6 flex flex-col">
<div class="flex justify-between items-center mb-6">
<h3 class="font-headline font-bold text-xl flex items-center gap-3">
<span class="material-symbols-outlined text-outline" data-icon="analytics">analytics</span>
                        Actes 2024
                    </h3>
</div>
<div class="relative h-44 w-full mb-4 bg-surface-container-high/40 rounded-xl overflow-hidden flex items-end px-4 pb-4 gap-2">
<!-- Bar Chart -->
<div class="flex-1 bg-primary/20 h-[50%] rounded-t-lg transition-all hover:bg-primary/40 group relative">
<div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-surface-container px-2 py-1 rounded text-[10px] hidden group-hover:block whitespace-nowrap">Jan: 110</div>
</div>
<div class="flex-1 bg-primary/30 h-[65%] rounded-t-lg transition-all hover:bg-primary/50 group relative"></div>
<div class="flex-1 bg-primary/40 h-[55%] rounded-t-lg transition-all hover:bg-primary/60 group relative"></div>
<div class="flex-1 bg-primary/50 h-[80%] rounded-t-lg transition-all hover:bg-primary/70 group relative"></div>
<div class="flex-1 bg-primary/60 h-[75%] rounded-t-lg transition-all hover:bg-primary/80 group relative"></div>
<div class="flex-1 bg-primary/70 h-[95%] rounded-t-lg transition-all hover:bg-primary/90 group relative"></div>
<div class="flex-1 bg-primary h-full rounded-t-lg transition-all hover:brightness-110 group relative"></div>
<div class="flex-1 bg-primary/80 h-[85%] rounded-t-lg transition-all hover:bg-primary/90 group relative"></div>
<div class="flex-1 bg-primary/70 h-[70%] rounded-t-lg transition-all hover:bg-primary/80 group relative"></div>
<div class="flex-1 bg-primary/60 h-[60%] rounded-t-lg transition-all hover:bg-primary/70 group relative"></div>
<div class="flex-1 bg-primary/50 h-[75%] rounded-t-lg transition-all hover:bg-primary/60 group relative"></div>
<div class="flex-1 bg-primary/40 h-[68%] rounded-t-lg transition-all hover:bg-primary/50 group relative"></div>
</div>
<div class="flex justify-between text-[10px] text-on-surface-variant font-bold px-1 uppercase mb-8">
<span>Jan</span><span>Fev</span><span>Mar</span><span>Avr</span><span>Mai</span><span>Jun</span><span>Jul</span><span>Aou</span><span>Sep</span><span>Oct</span><span>Nov</span><span>Dec</span>
</div>
<div class="overflow-x-auto custom-scrollbar">
<table class="w-full text-left text-sm border-collapse">
<thead class="text-on-surface-variant font-label border-b border-outline-variant/10">
<tr>
<th class="py-4 px-2 font-semibold">Type d'Acte</th>
<th class="py-4 px-2 text-right font-semibold">Volume</th>
<th class="py-4 px-2 text-right font-semibold">Croissance/23</th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant/5">
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Échographies</td>
<td class="py-4 px-2 text-right font-bold">582</td>
<td class="py-4 px-2 text-right text-secondary font-semibold">+12%</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">Sutures / Petite chir.</td>
<td class="py-4 px-2 text-right font-bold">148</td>
<td class="py-4 px-2 text-right text-secondary font-semibold">+5%</td>
</tr>
<tr class="hover:bg-white/5 transition-colors">
<td class="py-4 px-2 font-medium">ECG</td>
<td class="py-4 px-2 text-right font-bold">894</td>
<td class="py-4 px-2 text-right text-secondary font-semibold">+22%</td>
</tr>
</tbody>
</table>
</div>
</div>
</div>
<!-- Sticky Footer -->
<footer class="mt-auto py-6 px-8 border-t border-outline-variant/10 bg-surface-container-low/50 flex justify-between items-center backdrop-blur-md">
<div class="flex gap-4">
<span class="text-[10px] text-on-surface-variant font-medium uppercase tracking-widest">© 2025 The Clinical Atelier</span>
</div>
<p class="text-[10px] text-on-surface-variant font-bold tracking-widest uppercase opacity-60">
                PatientManager <span class="text-primary/80">v0.10.0</span>
</p>
</footer>
</main>
</body></html>