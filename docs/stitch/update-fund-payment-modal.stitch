<!DOCTYPE html>

<html class="light" lang="fr"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>The Clinical Atelier - Modifier le groupe de paiement</title>
<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-bright": "#fef7ff",
                        "on-tertiary": "#ffffff",
                        "inverse-primary": "#cfbcff",
                        "surface-container": "#f2ecf4",
                        "inverse-surface": "#322f35",
                        "on-secondary-fixed-variant": "#4b4263",
                        "surface-dim": "#ded8e0",
                        "on-error": "#ffffff",
                        "on-primary-container": "#e0d2ff",
                        "outline-variant": "#cbc4d2",
                        "inverse-on-surface": "#f5eff6",
                        "secondary": "#63597c",
                        "on-surface": "#1d1b20",
                        "surface-container-high": "#ede6ee",
                        "on-background": "#1d1b20",
                        "on-primary-fixed": "#22005d",
                        "primary-container": "#6750a4",
                        "surface": "#fef7ff",
                        "error": "#ba1a1a",
                        "on-tertiary-container": "#503d00",
                        "on-tertiary-fixed": "#241a00",
                        "primary-fixed-dim": "#cfbcff",
                        "on-tertiary-fixed-variant": "#594400",
                        "surface-container-highest": "#e7e0e8",
                        "on-primary": "#ffffff",
                        "on-secondary-fixed": "#1f1635",
                        "tertiary-container": "#c9a74d",
                        "error-container": "#ffdad6",
                        "tertiary-fixed": "#ffdf93",
                        "surface-container-lowest": "#ffffff",
                        "tertiary": "#765b00",
                        "on-secondary-container": "#645a7d",
                        "on-secondary": "#ffffff",
                        "secondary-fixed-dim": "#cdc0e9",
                        "tertiary-fixed-dim": "#e7c365",
                        "primary": "#4f378a",
                        "primary-fixed": "#e9ddff",
                        "outline": "#7a7582",
                        "surface-container-low": "#f8f1f9",
                        "on-surface-variant": "#494551",
                        "on-primary-fixed-variant": "#4f378a",
                        "background": "#fef7ff",
                        "secondary-container": "#e1d4fd",
                        "on-error-container": "#93000a",
                        "secondary-fixed": "#e9ddff",
                        "surface-tint": "#6750a4",
                        "surface-variant": "#e7e0e8"
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Manrope"],
                        "label": ["Manrope"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body { font-family: 'Manrope', sans-serif; }
        .glass-modal {
            background: #F4F3F7;
        }
    </style>
</head>
<body class="bg-surface text-on-surface overflow-hidden">
<!-- Background Dashboard (Blurred) -->
<div class="fixed inset-0 z-0 flex blur-md opacity-40">
<!-- SideNav Simulation -->
<aside class="w-64 bg-surface-container-low h-screen py-6 pr-4 flex flex-col">
<div class="px-6 mb-8 flex items-center gap-3">
<div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center text-white">
<span class="material-symbols-outlined">medical_services</span>
</div>
<div>
<div class="font-bold text-primary text-sm">Atelier Médical</div>
<div class="text-[10px] text-on-surface-variant">Cabinet de Gestion</div>
</div>
</div>
<nav class="flex-1 space-y-1">
<div class="flex items-center gap-3 px-6 py-3 bg-primary-fixed text-on-primary-fixed rounded-r-full font-semibold text-sm">
<span class="material-symbols-outlined">dashboard</span> Overview
                </div>
<div class="flex items-center gap-3 px-6 py-3 text-on-surface-variant text-sm">
<span class="material-symbols-outlined">calendar_today</span> Schedule
                </div>
<div class="flex items-center gap-3 px-6 py-3 text-on-surface-variant text-sm">
<span class="material-symbols-outlined">euro_symbol</span> Billing
                </div>
</nav>
</aside>
<!-- Main Content Simulation -->
<main class="flex-1 p-10">
<header class="flex justify-between items-center mb-10">
<h1 class="text-3xl font-extrabold tracking-tight text-primary">Dashboard</h1>
<div class="flex gap-4">
<span class="material-symbols-outlined p-2 bg-surface-container rounded-full">notifications</span>
<div class="w-10 h-10 rounded-full bg-outline-variant"></div>
</div>
</header>
<div class="grid grid-cols-3 gap-8">
<div class="h-40 bg-surface-container-lowest rounded-xl shadow-sm"></div>
<div class="h-40 bg-surface-container-lowest rounded-xl shadow-sm"></div>
<div class="h-40 bg-surface-container-lowest rounded-xl shadow-sm"></div>
<div class="col-span-3 h-80 bg-surface-container-lowest rounded-xl shadow-sm"></div>
</div>
</main>
</div>
<!-- Modal Overlay -->
<div class="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-sm p-4">
<!-- Modal Dialog -->
<div class="glass-modal w-full max-w-2xl max-h-[95vh] flex flex-col rounded-2xl shadow-2xl overflow-hidden">
<!-- Header -->
<div class="px-12 pt-10 pb-8">
<h2 class="text-[28px] font-bold tracking-tight text-on-surface">Modifier le groupe de paiement</h2>
</div>
<!-- Scrollable Content -->
<div class="flex-1 overflow-y-auto px-12 space-y-10 pb-6">
<!-- Read-only Info -->
<div class="grid grid-cols-2 gap-8 bg-white/50 p-6 rounded-xl border border-white/40">
<div class="flex flex-col gap-1">
<span class="text-[11px] font-bold uppercase tracking-[0.1em] text-on-surface-variant/70">Caisse</span>
<div class="text-on-surface font-semibold text-base">CPAM de Paris</div>
</div>
<div class="flex flex-col gap-1">
<span class="text-[11px] font-bold uppercase tracking-[0.1em] text-on-surface-variant/70">Identifiant</span>
<div class="text-on-surface font-semibold text-base">12345678</div>
</div>
</div>
<!-- Date Picker Field -->
<div class="space-y-2">
<label class="block text-[13px] font-bold text-on-surface-variant/80 ml-0.5">DATE DE PAIEMENT *</label>
<div class="relative group">
<input class="w-full bg-white border border-outline-variant/30 focus:border-primary/50 focus:ring-0 rounded-lg py-3.5 px-5 text-on-surface text-sm transition-all shadow-sm" type="text" value="24/05/2024"/>
<span class="material-symbols-outlined absolute right-5 top-1/2 -translate-y-1/2 text-primary text-[20px]">calendar_today</span>
</div>
</div>
<!-- Section: Actes en cours -->
<section class="space-y-4">
<h3 class="text-lg font-bold text-on-surface tracking-tight">
                        Actes en cours
                    </h3>
<div class="space-y-3">
<!-- Row 1 -->
<div class="flex items-center justify-between p-5 bg-white rounded-xl shadow-sm border border-transparent hover:border-primary/10 transition-all">
<div class="flex items-center gap-5">
<div class="w-6 h-6 rounded bg-primary flex items-center justify-center shadow-sm shrink-0">
<span class="material-symbols-outlined text-white text-[16px]" style="font-variation-settings: 'FILL' 1;">check</span>
</div>
<div class="flex flex-col justify-center">
<div class="text-[15px] font-bold text-on-surface leading-tight">Jean Dupont</div>
<div class="text-[13px] text-on-surface-variant/70 font-medium">12 Mai 2024 • Consultation</div>
</div>
</div>
<div class="text-[15px] font-bold text-on-surface tabular-nums">25.00 €</div>
</div>
<!-- Row 2 -->
<div class="flex items-center justify-between p-5 bg-white rounded-xl shadow-sm border border-transparent hover:border-primary/10 transition-all">
<div class="flex items-center gap-5">
<div class="w-6 h-6 rounded bg-primary flex items-center justify-center shadow-sm shrink-0">
<span class="material-symbols-outlined text-white text-[16px]" style="font-variation-settings: 'FILL' 1;">check</span>
</div>
<div class="flex flex-col justify-center">
<div class="text-[15px] font-bold text-on-surface leading-tight">Marie Curie</div>
<div class="text-[13px] text-on-surface-variant/70 font-medium">14 Mai 2024 • Analyse Sanguine</div>
</div>
</div>
<div class="text-[15px] font-bold text-on-surface tabular-nums">48.45 €</div>
</div>
<!-- Row 3 -->
<div class="flex items-center justify-between p-5 bg-white rounded-xl shadow-sm border border-transparent hover:border-primary/10 transition-all">
<div class="flex items-center gap-5">
<div class="w-6 h-6 rounded bg-primary flex items-center justify-center shadow-sm shrink-0">
<span class="material-symbols-outlined text-white text-[16px]" style="font-variation-settings: 'FILL' 1;">check</span>
</div>
<div class="flex flex-col justify-center">
<div class="text-[15px] font-bold text-on-surface leading-tight">Pierre Martin</div>
<div class="text-[13px] text-on-surface-variant/70 font-medium">15 Mai 2024 • Kinésithérapie</div>
</div>
</div>
<div class="text-[15px] font-bold text-on-surface tabular-nums">50.00 €</div>
</div>
</div>
</section>
<!-- Summary Bar -->
<div class="py-5 px-6 bg-[#E9E4F9] rounded-xl flex justify-between items-center">
<span class="text-[14px] font-semibold text-primary">3 actes sélectionnés</span>
<span class="text-[18px] font-bold text-primary tracking-tight">Total: 123.45 €</span>
</div>
</div>
<!-- Footer Buttons -->
<div class="px-12 py-10 flex justify-end items-center gap-4 bg-surface-container-low/30 border-t border-outline-variant/10">
<button class="h-11 px-8 text-[14px] font-bold text-on-surface-variant border border-outline-variant/50 hover:bg-surface-container-highest transition-all rounded-lg">
                    Annuler
                </button>
<div class="flex-1"></div>
<button class="h-11 px-6 text-[14px] font-bold text-primary border border-primary/20 bg-white hover:bg-primary/5 transition-all rounded-lg flex items-center gap-2">
<span class="material-symbols-outlined text-[18px]">add</span>
                    Ajouter un acte
                </button>
<button class="h-11 px-10 text-[14px] font-bold text-white bg-primary hover:bg-primary/90 shadow-[0_4px_12px_rgba(79,55,138,0.25)] active:scale-[0.98] transition-all rounded-lg">
                    Mettre à jour
                </button>
</div>
</div>
</div>
</body></html>