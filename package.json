{
  "name": "vault-compass",
  "author": "Philippe Eggel",
  "license": "MIT",
  "private": true,
  "version": "0.9.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "biome check .",
    "format:fix": "biome check --write .",
    "format:unsafe": "biome check --write --unsafe .",
    "format:docs": "prettier --write \"**/*.md\" --ignore-path .gitignore",
    "stats": "cloc . --vcs=git --exclude-dir=node_modules,target --exclude-ext=json,lock,yaml",
    "test:e2e": "wdio run wdio.conf.ts",
    "test:e2e:xvfb": "xvfb-run --auto-servernum npm run test:e2e"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@headlessui/react": "^2.2.9",
    "@tanstack/react-router": "^1.168.22",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2",
    "fuse.js": "^7.1.0",
    "i18next": "^26.0.1",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@wdio/cli": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "happy-dom": "^20.3.9",
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "webdriverio": "^9.27.1"
  }
}
