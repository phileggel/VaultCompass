{
  "name": "portfolio-manager",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "biome check .",
    "format:fix": "biome check --write .",
    "format:unsafe": "biome check --write --unsafe .",
    "format:docs": "prettier --write \"**/*.md\" --ignore-path .gitignore",
    "stats": "cloc . --vcs=git --exclude-dir=node_modules,target --exclude-ext=json,lock,yaml"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@headlessui/react": "^2.2.9",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "fuse.js": "^7.1.0",
    "i18next": "^25.10.10",
    "lucide-react": "^0.563.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.6.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.3",
    "happy-dom": "^20.3.9",
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
